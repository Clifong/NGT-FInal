    <IsRememberChoiceNode>k__BackingField: 0
    <RememberSO>k__BackingField: {fileID: 0}
    ChoiceSO:
    - {fileID: 0}
    BackgroundImage: {fileID: -2441277322969603615, guid: 5d833bbe5effc5245b8c8e5380102d6f, type: 3}
  - <ID>k__BackingField: e187fe49-79bf-4f97-94e6-db17f5dbfb76
    <Name>k__BackingField: DialogueName10
    <Choices>k__BackingField:
    - <Text>k__BackingField: New Choice
      <NodeID>k__BackingField: 
    <GroupID>k__BackingField: 
    <Position>k__BackingField: {x: 6978.4, y: 90.4}
    <Text>k__BackingField: 'Consequently, the increase in consumption of beauty products
      amongst chinese men is a way of challenging how masculintiy is potrayed in
      China. Now, more men in China are starting to embrace the more contemporary
      form of masculinity which has an emphasis on softness. '
    <Actions>k__BackingField: []
