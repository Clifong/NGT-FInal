    <Name>k__BackingField: DialogueName2
    <Choices>k__BackingField:
    - <Text>k__BackingField: How did traditional masculinity come about?
      <NodeID>k__BackingField: ecfd7f56-4486-461f-898d-a47d87907111
    - <Text>k__BackingField: Continue...
      <NodeID>k__BackingField: 82315d37-f628-4d6f-8616-90d4f90ee766
    <GroupID>k__BackingField: 
    <Position>k__BackingField: {x: 977.6, y: 53.6}
    <Text>k__BackingField: 'Traditional American masculinity emphasises physical
      strength, stoicism and independence.

'
    <Actions>k__BackingField: []
