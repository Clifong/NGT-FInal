  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '- We have discussed what is happening to male character designs in American
    and China video games


    - We have discussed how contemporary masculinity
    in both countries that shaped this design are influenced by capitalism


    American:

    (1)
    Higher income -> Higher enrollment in college/universities -> Men becomes influenced
    and start adopting liberal values of masculinity

    (2) Higher cost of living
    -> Greater pressure on men -> Some men rejecting traditional roles -> Want more
    women to work -> Men adopt gentler masculinity so feminism succeeds and more
    women work


    China:

    (1) Growing income -> Women consume more South Korean
    culture -> More export of South Korean culture -> Demand for softer masculinity
    increase and it becomes more appealing

    (2) Higher cost of living -> More
    women working -> More men to take up nurturer role -> Men need to adopt softer
    form of masculinity

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
